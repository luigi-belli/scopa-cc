# ─── External Access Configuration ───

# Hostname visible to users (used for TLS certificate and Caddy SERVER_NAME)
EXTERNAL_HOSTNAME=scopa.example.com

# Port visible to users after NAT forwarding (used in HTTP/3 Alt-Svc and redirects)
EXTERNAL_PORT=59820

# ─── Docker Host Port ───

# Port Docker listens on locally (NAT forwards EXTERNAL_PORT → INTERNAL_PORT → container:443)
INTERNAL_PORT=5982

# ─── TLS Certificate Mode ───

# "selfsigned"  — Caddy auto-generated internal CA cert (local dev)
# "letsencrypt" — automated via Let's Encrypt + Dynu DNS (production)
TLS_MODE=selfsigned

# ─── Let's Encrypt + Dynu DNS (only used when TLS_MODE=letsencrypt) ───

# Dynu DNS API credentials (https://www.dynu.com/en-US/ControlPanel/APICredentials)
DYNU_CLIENT_ID=
DYNU_SECRET=
