# ─── External Access Configuration ───

# Hostname visible to users (used for TLS certificate CN and server_name)
EXTERNAL_HOSTNAME=scopa.example.com

# Port visible to users after NAT forwarding (used in HTTP/3 Alt-Svc and redirects)
EXTERNAL_PORT=59820

# ─── Docker Host Port ───

# Port Docker listens on locally (NAT forwards EXTERNAL_PORT → INTERNAL_PORT → container:443)
INTERNAL_PORT=5982
