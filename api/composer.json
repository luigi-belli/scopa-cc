{
    "name": "scopa/api",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "api-platform/core": "^4.1",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.3",
        "symfony/console": "^7.3",
        "symfony/dotenv": "^7.3",
        "symfony/framework-bundle": "^7.3",
        "symfony/doctrine-messenger": "^7.3",
        "symfony/messenger": "^7.3",
        "symfony/mercure": "^0.6",
        "symfony/mercure-bundle": "^0.3 || ^0.4",
        "symfony/property-access": "^7.3",
        "symfony/property-info": "^7.3",
        "symfony/serializer": "^7.3",
        "symfony/uid": "^7.3",
        "symfony/var-exporter": "^7.3",
        "symfony/validator": "^7.3",
        "symfony/yaml": "^7.3",
        "symfony/runtime": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.3",
        "symfony/http-client": "^7.3",
        "symfony/phpunit-bridge": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
